// Solution 1
class Solution {
    public int countNumbersWithUniqueDigits(int n) {
        if(n==0){
            return 1;
        }
        int ans = 10;
        int unique = 9;
        int avail = 9;
        for(int i=2;i<=n;i++){
            unique *= avail;
            ans+=unique;
            avail--;
        }
        return ans;
    }
}
// Solution 2
class Solution {
    public int countNumbersWithUniqueDigits(int n) {
       if(n==0){
        return 1;
       }
       int[] dp = new int[n+1];
       dp[0]=1;
       dp[1]=10;
       int product=9;
       for(int i=2;i<=n;i++){
        product *= (11-i);
        dp[i] = dp[i-1]+product;
       }
       return dp[n];
    }
}
